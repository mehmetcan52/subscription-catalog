ome/reviews/cloudwards.svg\",\"readMoreLink\":\"https://www.cloudwards.net/review/pcloud/\",\"imagePosition\":\"between\",\"mobileImagePosition\":\"between\"},{\"id\":3,\"title\":{\"t_text\":\"reviews_slide_3\",\"t_default\":\"\\\"pCloud offers great performance, simple file sharing with password protection and expiration dates, plus unmatched lifetime plans.\\\"\"},\"image\":\"//pcdn-www.pcloud.com/ZWdcT/images/animated-home/reviews/gizmodo.svg\",\"readMoreLink\":\"https://gizmodo.com/best-cloud-storage\",\"imagePosition\":\"between\",\"mobileImagePosition\":\"between\"}],\"de\":[{\"id\":1,\"title\":\"\\\"pCloud ist ein Cloud-Speicher mit deutlichem Fokus auf digitale Mediadateien.\\\"\",\"image\":\"//pcdn-www.pcloud.com/ZWdcT/images/animated-home/reviews/netzsieger.svg\",\"readMoreLink\":\"https://www.netzsieger.de/p/pcloud\",\"imagePosition\":\"between\",\"mobileImagePosition\":\"between\"},{\"id\":2,\"title\":\"\\\"Mit der Kombination aus solider Sicherheit und fairer Preisgestaltung kann uns pCloud überzeugen.\\\"\",\"image\":\"//pcdn-www.pcloud.com/ZWdcT/images/animated-home/reviews/netzwelt.svg\",\"readMoreLink\":\"https://www.netzwelt.de/cloud-speicher/pcloud-testbericht.html\",\"imagePosition\":\"between\",\"mobileImagePosition\":\"between\"},{\"id\":3,\"title\":\"\\\"pCloud ist in diesem Jahr Cloud-Speicher-Testsieger. Die Gründe: Hohe Sicherheitsstandards, gutes Preis-Leistungs-Verhältnis und top Usability.\\\"\",\"image\":\"//pcdn-www.pcloud.com/ZWdcT/images/animated-home/reviews/trusted.svg\",\"readMoreLink\":\"https://trusted.de/cloud-speicher#pcloud\",\"imagePosition\":\"between\",\"mobileImagePosition\":\"between\"}],\"fr\":[{\"id\":1,\"title\":\"\\\"Basé en Suisse, pCloud est l'un des rares hébergeurs à garantir une sécurité et confidentialité sans faille.\\\"\",\"image\":\"//pcdn-www.pcloud.com/ZWdcT/images/animated-home/reviews/clubic.svg\",\"readMoreLink\":\"https://www.clubic.com/stockage-en-ligne/guide-21001-meilleur-stockage-cloud.html\",\"imagePosition\":\"between\",\"mobileImagePosition\":\"between\"},{\"id\":2,\"title\":\"\\\"Le meilleur cloud en ligne grâce à son service de qualité et sa plateforme ergonomique et rapide.\\\"\",\"image\":\"//pcdn-www.pcloud.com/ZWdcT/images/animated-home/reviews/01net.svg\",\"readMoreLink\":\"https://www.01net.com/cloud/\",\"imagePosition\":\"between\",\"mobileImagePosition\":\"between\"},{\"id\":3,\"title\":\"\\\"pCloud est le meilleur service de stockage en ligne avec un rapport qualité/prix excellent.\\\"\",\"image\":\"//pcdn-www.pcloud.com/ZWdcT/images/animated-home/reviews/pressecitron.svg\",\"readMoreLink\":\"https://www.presse-citron.net/stockage-en-ligne/\",\"imagePosition\":\"between\",\"mobileImagePosition\":\"between\"}],\"es\":[{\"id\":1,\"title\":\"\\\"pCloud destaca por ofrecer una solución con almacenamiento seguro, pago único de por vida y gran versatilidad.\\\"\",\"image\":\"//pcdn-www.pcloud.com/ZWdcT/images/animated-home/reviews/andro4all.svg\",\"readMoreLink\":\"https://andro4all.com/aplicaciones/los-7-mejores-servicios-de-almacenamiento-en-la-nube-de-2023-manten-tus-archivos-a-salvo\",\"imagePosition\":\"between\",\"mobileImagePosition\":\"between\"},{\"id\":2,\"title\":\"\\\"pCloud es una de las mejores alternativas por su facilidad de uso, velocidad y opciones de seguridad robustas.\\\"\",\"image\":\"//pcdn-www.pcloud.com/ZWdcT/images/animated-home/reviews/01net.svg\",\"readMoreLink\":\"https://www.01net.com/es/almacenamiento-nube/\",\"imagePosition\":\"between\",\"mobileImagePosition\":\"between\"},{\"id\":3,\"title\":\"\\\"Este servicio ofrece almacenamiento seguro, privacidad total y funciones avanzadas para usuarios exigentes.\\\"\",\"image\":\"//pcdn-www.pcloud.com/ZWdcT/images/animated-home/reviews/redeszone.svg\",\"readMoreLink\":\"https://www.redeszone.net/analisis/software/pcloud-almacenamiento-nube-cloud-premium/\",\"imagePosition\":\"between\",\"mobileImagePosition\":\"between\"}],\"it\":[{\"id\":1,\"title\":\"\\\"pCloud è una soluzione cloud ideale per chi cerca privacy e spazio a vita, affidabile nel lungo termine.\\\"\",\"image\":\"//pcdn-www.pcloud.com/ZWdcT/images/animated-home/reviews/hdblog.svg\",\"readMoreLink\":\"https://www.hdblog.it/applicazioni/guide/n612251/pcloud-recensione/\",\"imagePosition\":\"between\",\"mobileImagePosition\":\"between\"},{\"id\":2,\"title\":\"\\\"pCloud è semplice da usare, veloce e sicuro con ottimo rapporto qualità-prezzo.\\\"\",\"image\":\"//pcdn-www.pcloud.com/ZWdcT/images/animated-home/reviews/01net.svg\",\"readMoreLink\":\"https://www.01net.com/it/cloud-storage/pcloud/\",\"imagePosition\":\"between\",\"mobileImagePosition\":\"between\"},{\"id\":3,\"title\":\"\\\"pCloud offre spazio stabile, prestazioni elevate e sicurezza avanzata.\\\"\",\"image\":\"//pcdn-www.pcloud.com/ZWdcT/images/animated-home/reviews/punto-informatico.svg\",\"readMoreLink\":\"https://www.punto-informatico.it/pcloud-recensione/\",\"imagePosition\":\"between\",\"mobileImagePosition\":\"between\"}],\"ja\":[{\"id\":1,\"title\":\"個人的にはpCloudはクラウドストレージの利点が最大限に利用できるサービスだと思っています。\",\"image\":\"//pcdn-www.pcloud.com/ZWdcT/images/animated-home/reviews/blankcoin.svg\",\"readMoreLink\":\"https://blankcoin.com/?p=6802\",\"imagePosition\":\"between\",\"mobileImagePosition\":\"between\"},{\"id\":2,\"title\":\"「あれ、pCloudって結構お得なんじゃ」と感じた方も多いと思います。しかもpCloudを利用すれば外付けSSDの不満を一気に解決できます\",\"image\":\"//pcdn-www.pcloud.com/ZWdcT/images/animated-home/reviews/sukiburo.svg\",\"readMoreLink\":\"https://sukiburo.jp/pcloud/#1\",\"imagePosition\":\"between\",\"mobileImagePosition\":\"between\"},{\"id\":3,\"title\":\"長期間使うことを想定して、価格を比較すると、買い切りモデルがいかにお得か実感いただけるはず。\",\"image\":\"//pcdn-www.pcloud.com/ZWdcT/images/animated-home/reviews/macfan.svg\",\"readMoreLink\":\"https://macfan.book.mynavi.jp/article/41667/\",\"imagePosition\":\"between\",\"mobileImagePosition\":\"between\"}],\"zh\":[{\"id\":1,\"title\":\"我個人認為pCloud是目前眾多雲端硬碟選擇當中，整體評價最好的品牌，該有的功能都相當完整，尤其是電腦軟體版相當好用。\",\"image\":\"//pcdn-www.pcloud.com/ZWdcT/images/animated-home/reviews/benic360.svg\",\"readMoreLink\":\"https://benic360.com/best-cloud-drive-services/\",\"imagePosition\":\"between\",\"mobileImagePosition\":\"between\"},{\"id\":2,\"title\":\"pCloud的卓越之處體現在其安全性、靈活性和持久性上。該服務以強大的加密技術保障用戶數據的安全性，同時提供靈活的儲存方案，滿足不同用戶的個性化需求。\",\"image\":\"//pcdn-www.pcloud.com/ZWdcT/images/animated-home/reviews/mytechgirl.svg\",\"readMoreLink\":\"https://www.mytechgirl.com/tw/cloud/pcloud-prices-and-plans-mtg6688.html\",\"imagePosition\":\"between\",\"mobileImagePosition\":\"between\"},{\"id\":3,\"title\":\"pCloud 是一家非常注重資料安全性的公司，曾在 2016 年獲得 Best Cloud Security 獎項。即便到今日，未曾發生過任何資安新聞。\",\"image\":\"//pcdn-www.pcloud.com/ZWdcT/images/animated-home/reviews/aidaidme.svg\",\"readMoreLink\":\"https://aidaidme.com/pcloud-cloud-storage-intro/\",\"imagePosition\":\"between\",\"mobileImagePosition\":\"between\"}]}}},{\"componentName\":\"ScrollAnimationSection\",\"props\":{\"animationSpeed\":0.6,\"backgroundImageTopOffset\":0,\"backgroundImageWidth\":1920,\"backgroundImageHeight\":1080,\"startingSectionWidth\":1180,\"startingSectionHeight\":664,\"viewportStartOffset\":48,\"hideTabsNavigation\":false,\"hideArrowsNavigation\":false,\"startImageOverlayColorOnSecondElementFadeOut\":false,\"showTabTextBeforeSecondElementFadeOutFinished\":false,\"tabContentStartPointDelay\":0,\"content\":{\"firstElement\":{\"text\":{\"t_text\":\"home_scroll_animated_section_first_text\",\"t_default\":\"Still wondering if pCloud is for you?\"}},\"secondElement\":{\"text\":{\"t_text\":\"home_scroll_animated_section_second_text\",\"t_default\":\"See how others use it.\"}},\"heroImage\":{\"src\":\"//pcdn-www.pcloud.com/ZWdcT/images/animated-home/scroll-animation-section/bg.jpg\",\"width\":1920,\"height\":1080},\"heroImageBlurred\":{\"src\":\"//pcdn-www.pcloud.com/ZWdcT/images/animated-home/scroll-animation-section/bg-blurred.jpg\",\"width\":1920,\"height\":1080},\"tabsData\":[{\"label\":{\"t_text\":\"Photographers\",\"t_default\":\"Photographers\"},\"title\":{\"t_text\":\"phot